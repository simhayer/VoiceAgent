DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Twilio master account (shared across all tenants)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# OpenAI (Realtime API)
OPENAI_API_KEY=your_openai_key

# Supabase (Settings > API in your Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co
# Optional for modern asymmetric JWT projects; required only if your tokens are HS*
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=your-anon-key
ENABLE_AUTH_DEBUG_ENDPOINT=false


# Server
SERVER_URL=https://your-server.com

# Redis Cloud (free tier): https://app.redislabs.com
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:your_password@redis-12345.c1.us-east-1-2.ec2.redns.redis-cloud.com:12345
